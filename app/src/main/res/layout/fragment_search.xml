<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <EditText
        android:id="@+id/editSearch"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#2D2D2D"
        android:hint="Search Hentai..."
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="8dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGenres"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Genres\nSelect"
                android:backgroundTint="#2D2D2D"
                android:textColor="#BBBBBB"
                android:textAllCaps="false"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnBlacklist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blacklist\nSelect"
                android:backgroundTint="#2D2D2D"
                android:textColor="#BBBBBB"
                android:textAllCaps="false"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnStudios"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Studios\nSelect"
                android:backgroundTint="#2D2D2D"
                android:textColor="#BBBBBB"
                android:textAllCaps="false" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <Spinner
            android:id="@+id/spinnerSort"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:background="#2D2D2D" />

        <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hide watched"
            android:textColor="#E3E3E3"
            android:layout_marginStart="16dp"/>
    </LinearLayout>
    
    <Button
        android:id="@+id/btnApplyFilters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Aplicar Filtros"
        android:backgroundTint="#BB86FC"
        android:textColor="#000000"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSearch"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:clipToPadding="false" />

    <ProgressBar
        android:id="@+id/progressSearch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</LinearLayout>
