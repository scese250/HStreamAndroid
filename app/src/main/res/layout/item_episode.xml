<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="12dp">
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
        <ImageView android:id="@+id/imgEpisodeThumbnail" android:layout_width="160dp" android:layout_height="90dp" android:scaleType="centerCrop" android:background="#2D2D2D"/>
        <TextView android:id="@+id/txtEpisodeTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="8dp" android:textColor="#FFF" android:textStyle="bold" android:textSize="14sp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
