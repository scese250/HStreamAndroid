<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona un video para reproducir:"
        android:textSize="18sp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnVideo1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Video 1 (Chiisana Tsubomi)"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnVideo2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Video 2 (Heart Mark Oome)"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnVideo3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Video 3 (Shinsei Futanari Idol)" />

</LinearLayout>
