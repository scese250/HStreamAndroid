<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:paddingTop="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">
        
        <TextView
            android:id="@+id/txtDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Genres &amp; Filters"
            android:textColor="#BB86FC"
            android:textSize="20sp"
            android:textStyle="bold" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select tags to filter your content."
            android:textColor="#888888"
            android:textSize="14sp" />
    </LinearLayout>
    
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2D2D2D"
        android:layout_marginTop="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Genres -->
            <TextView
                android:id="@+id/headerGenres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Genres"
                android:textColor="#E3E3E3"
                android:textSize="16sp"
                android:padding="16dp"
                android:background="@drawable/bg_box"
                android:textStyle="bold" />
            <GridLayout
                android:id="@+id/gridGenres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Actions -->
            <TextView
                android:id="@+id/headerActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Actions"
                android:textColor="#E3E3E3"
                android:textSize="16sp"
                android:padding="16dp"
                android:background="@drawable/bg_box"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
            <GridLayout
                android:id="@+id/gridActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Appearance -->
            <TextView
                android:id="@+id/headerAppearance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Appearance"
                android:textColor="#E3E3E3"
                android:textSize="16sp"
                android:padding="16dp"
                android:background="@drawable/bg_box"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
            <GridLayout
                android:id="@+id/gridAppearance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Types -->
            <TextView
                android:id="@+id/headerTypes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Types"
                android:textColor="#E3E3E3"
                android:textSize="16sp"
                android:padding="16dp"
                android:background="@drawable/bg_box"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
            <GridLayout
                android:id="@+id/gridTypes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
    
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2D2D2D" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">
        
        <Button
            android:id="@+id/btnDialogCancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:text="Cancel"
            android:backgroundTint="#1E1E1E"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnDialogSave"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:text="Apply Filters"
            android:backgroundTint="#BB86FC"
            android:textColor="#121212"
            android:layout_marginStart="16dp" />
    </LinearLayout>

</LinearLayout>
